[user]
	name = jmoriarty
	email = james_moriarty@intuit.com
[core]
  excludesfile = ~/.gitignore
  editor = vim
  pager = delta
[interactive]
  diffFilter = delta --color-only
[diff]
  tool = vimdiff
[alias]
  lg = log --all -n 30 --graph --pretty=format:'%C(yellow)%h%C(auto)%d%C(white) %s %C(dim bold cyan)%cr'
[color]
	ui = true
[log]
	date = local
[init]
	defaultbranch = master
[http]
	postBuffer = 524288000
[delta]
  navigate = true
  side-by-side = false
  line-numbers = true
  syntax-theme = Dracula
[credential "https://github.com"]
	helper =
	helper = !/opt/homebrew/bin/gh auth git-credential
[credential "https://gist.github.com"]
	helper =
	helper = !/opt/homebrew/bin/gh auth git-credential
[credential "https://github.intuit.com"]
	helper =
	helper = !/opt/homebrew/bin/gh auth git-credential
