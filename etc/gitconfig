[user]
	name = James Moriarty
	email = james@moriartys.co
[core]
  excludesfile = ~/.gitignore
  editor = vim
  pager = delta
[pager]
  log = delta
  show = delta
[merge]
  conflictstyle = diff3   # Shows base in conflicts
[interactive]
    diffFilter = delta --color-only
[delta]
    features = line-numbers decorations
    navigate = true          # Jump between diff sections with n / N
    syntax-theme = Monokai Extended
    side-by-side = false     # Set true if you want side-by-side diffs
[diff]
  tool = vimdiff
[difftool]
  prompt = false
[alias]
  lg = log --all -n 30 --graph --pretty=format:'%C(yellow)%h%C(auto)%d%C(white) %s %C(dim bold cyan)%cr'
[color]
	ui = true
[log]
	date = local
[init]
	defaultbranch = master
