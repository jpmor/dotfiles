[user]
	name = James Moriarty
	email = james@moriartys.co
[core]
  excludesfile = ~/.gitignore
  editor = vim
  pager = delta
[pager]
  log = delta
  show = delta
[merge]
  conflictstyle = diff3
[interactive]
  diffFilter = delta --color-only
[diff]
  tool = vimdiff
[alias]
  lg = log --all -n 30 --graph --pretty=format:'%C(yellow)%h%C(auto)%d%C(white) %s %C(dim bold cyan)%cr'
[color]
	ui = true
[log]
	date = local
[init]
	defaultbranch = master
[delta]
  navigate = true
  side-by-side = false
  line-numbers = true
  decorations = true
  syntax-theme = Dracula
[credential "https://github.com"]
	helper =
	helper = !/opt/homebrew/bin/gh auth git-credential
[credential "https://gist.github.com"]
	helper =
	helper = !/opt/homebrew/bin/gh auth git-credential
[credential "https://github.intuit.com"]
	helper =
	helper = !/opt/homebrew/bin/gh auth git-credential
[includeIf "gitdir:/Volumes/CaseSensitive/imc/"]
	path = ~/.dot/etc/gitconfig.intuit
